# ─────────────────────────────────────────────────────────────────────────────
# Ephemeral Cloud Kubernetes Resource Risk Detection — environment variables
#
# Copy this file to `.env` (in the ephemeral-risk/ folder) and fill in your
# real values. The .env file is git-ignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# HMAC secret used to verify incoming GitHub webhook signatures.
# Must match the "Secret" field on your GitHub repository webhook settings.
GITHUB_WEBHOOK_SECRET=devsecret

# ngrok authtoken — exposes the local server publicly so GitHub can reach it.
# Get one from https://dashboard.ngrok.com/get-started/your-authtoken
# Leave EMPTY to skip the ngrok tunnel (local-only operation).
NGROK_AUTHTOKEN=3FMaJoRSGOGoXl9LCfGJrQP78si_67ZfcWkzJxVm8V8aLmAEx

# JWT signing secret for authenticating dashboard users (analyst1 / admin1).
# Generate a strong random value, e.g.  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-hackathon-secret

# (Optional) Gemini API key for LLM triage reports. If unset, the correlator
# falls back to a local Ollama model, then to rule-based triage.
GEMINI_API_KEY=

# ── Email / SMTP Alert Settings ──────────────────────────────────────────────
# SMTP server for sending incident alert emails (CRITICAL & HIGH only).
# Leave EMPTY to disable email alerts — alerts will still be logged locally.
# Example for Gmail:  smtp.gmail.com
SMTP_HOST=smtp.gmail.com

# SMTP port (587 for TLS, 465 for SSL).
SMTP_PORT=587

# Sender email address (e.g. yourapp@gmail.com).
SMTP_USER=aaryamannprabhu01@gmail.com

# SMTP password or app-specific password.
# For Gmail use an App Password: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=nxyz jlos ykgv lvgq

# Comma-separated recipient addresses for alerts.
ALERT_RECIPIENT=achintyak30@gmail.com
